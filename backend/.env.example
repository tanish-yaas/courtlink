# Port the server listens on (Render/Railway set this automatically).
PORT=8080

# Comma-separated list of allowed browser origins (your deployed frontend).
# Use "*" for quick local testing only. In production set your real URL:
#   CORS_ORIGIN=https://your-app.vercel.app
# You can include localhost too while developing:
#   CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=*
